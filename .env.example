# Shared-secret bearer token. Generate one with:
#   openssl rand -base64 36 | tr -d '=+/' | head -c 48
DELEGATE_TOKEN=REPLACE_ME

# Bind config. 0.0.0.0 listens on all interfaces; lock to a VPN IP if needed.
DELEGATE_HOST=0.0.0.0
DELEGATE_PORT=4115

# Default working directory when a caller doesn't specify one.
DELEGATE_DEFAULT_CWD=/home/youruser

# Hard cap (seconds) on any single delegate call.
DELEGATE_MAX_TIMEOUT=1800

# Path to the `claude` CLI on this host.
CLAUDE_BIN=/home/youruser/.local/bin/claude
